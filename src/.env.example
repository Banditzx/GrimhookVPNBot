# Telegram Bot Settings
BOT_TOKEN=1234567890:replace_with_botfather_token
ADMINS=123456789,987654321
TRIAL_DAYS=1

# Web admin panel password. Set a long random value in src/.env.
ADMIN_PANEL_PASSWORD=replace_with_long_random_password

# Subscription prices in RUB. Bot converts them to Telegram Stars + markup.
PRICE_1_DAY_RUB=25
PRICE_7_DAYS_RUB=125
PRICE_1_MONTH_RUB=350
PRICE_2_MONTHS_RUB=700
PRICE_3_MONTHS_RUB=1050
DISCOUNT_1_DAY_PERCENT=0
DISCOUNT_7_DAYS_PERCENT=0
DISCOUNT_1_MONTH_PERCENT=0
DISCOUNT_2_MONTHS_PERCENT=0
DISCOUNT_3_MONTHS_PERCENT=0

# Telegram Stars conversion settings
STAR_PRICE_MARKUP_PERCENT=10
STAR_RUB_RATE=1.66

# 3x-ui Panel Settings
XUI_API_URL=http://your-domain.com:2053
XUI_HOST=your-domain.com
XUI_BASE_PATH=/your-secret-path
XUI_SERVER_NAME="VPN_SERVER"
XUI_USERNAME=admin
XUI_TOKEN=your_3x_ui_api_token
INBOUND_ID=1
XUI_MANAGED_CLIENT_PREFIX=user_

# Reality Settings
REALITY_PUBLIC_KEY=your_public_key_from_panel
REALITY_FINGERPRINT=chrome
REALITY_SNI=google.com
REALITY_SHORT_ID=short_id_1,short_id_2
REALITY_SPIDER_X=/
# Optional: SQLite database path. Docker compose overrides it to /app/data/users.db.
BOT_DATABASE_PATH=users.db

